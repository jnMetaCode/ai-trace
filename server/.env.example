# AI-Trace Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Deployment Mode
# ===========================================
# "simple" = SQLite only, no external dependencies
# "standard" = PostgreSQL + Redis + MinIO (production)
DEPLOY_MODE=simple

# ===========================================
# SQLite Configuration (Simple Mode)
# ===========================================
SQLITE_PATH=./data/ai-trace.db

# ===========================================
# Database Configuration (Standard Mode)
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_NAME=ai_trace
DB_SSLMODE=disable  # Use 'require' in production

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=  # Set a password in production

# ===========================================
# MinIO / S3 Configuration
# ===========================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# For AWS S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=ai-trace

# ===========================================
# Authentication
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# API Keys (comma-separated for multiple keys)
API_KEYS=key1,key2,key3

# ===========================================
# AI Provider Keys
# ===========================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ===========================================
# Blockchain Configuration (Optional - legal level)
# ===========================================
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR-PROJECT-ID
# ETHEREUM_PRIVATE_KEY=0x...
# ETHEREUM_CONTRACT_ADDRESS=0x...

# For Polygon:
# POLYGON_RPC_URL=https://polygon-rpc.com
# POLYGON_PRIVATE_KEY=0x...

# ===========================================
# Monitoring (Optional)
# ===========================================
# SENTRY_DSN=https://...@sentry.io/...
# PROMETHEUS_ENABLED=true

# ===========================================
# Feature Flags
# ===========================================
FEATURE_BLOCKCHAIN_ANCHOR=false
FEATURE_FEDERATED_NODES=false
FEATURE_METRICS=true
